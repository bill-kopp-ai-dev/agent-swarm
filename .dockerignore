# Dependencies
node_modules/

# Logs
logs/
*.log

# Bindings
work/

# Database
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Git
.git/
.gitignore

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
*.tsbuildinfo

# Environment files (secrets should be passed via env vars)
.env
.env.*
!.env.example

# Backup files
*.bak

# Claude local config (will be created in container)
.claude/
.mcp.json

# Test files
*.test.ts
*.spec.ts
__tests__/
coverage/

# Documentation
*.md
!cc-plugin/**/*.md
!templates/skills/**/*.md

# Other dockerfiles and compose files
Dockerfile
docker-compose.yml
docker-compose.*.yml
!docker-compose.worker.yml

# Eval harness sub-project (included for apps/evals/Dockerfile only; the root
# Dockerfiles COPY only its package.json). The member manifests must stay in the
# build context: the root package.json declares the apps/* Bun workspace members,
# so `bun install --frozen-lockfile` in the builders needs them to resolve the graph.
apps/evals/
!apps/evals/
!apps/evals/**
apps/evals/**/*.test.ts
apps/evals/**/*.spec.ts
apps/evals/**/node_modules/
apps/evals/ui/dist/
apps/evals/evals.db
apps/evals/evals.db-shm
apps/evals/evals.db-wal
apps/evals/evals-replica.db*
